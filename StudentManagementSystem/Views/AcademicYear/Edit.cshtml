@model StudentManagementSystem.PL.ViewModel.AcademicYear.AcademicYearVm

@{
    ViewData["Title"] = "Edit Academic Year";
}

<h2>Edit Academic Year</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <button class="btn btn-warning">Update</button>
    <a asp-action="GetAll" class="btn btn-secondary">Back</a>
</form>

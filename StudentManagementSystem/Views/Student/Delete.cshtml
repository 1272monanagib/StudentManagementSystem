@using StudentManagementSystem.PL.ViewModel.Student
@model GetStudentVm

<div class="card p-3">
    <h4>Are you sure you want to delete this student?</h4>
    <p><strong>@Model.Name</strong> (@Model.Email) - Age: @Model.Age</p>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="GetAll" class="btn btn-secondary">Cancel</a>
    </form>
</div>
